
@baseUrl = http://localhost:8080
@apiUrl = {{baseUrl}}/api
@tipoId = 1
@caballoId = 1

### =========================
### Health check rapido
### =========================
GET {{baseUrl}}/actuator/health
Accept: application/json

### =========================
### TIPOS DE CABALLO
### =========================

### Listar tipos
GET {{apiUrl}}/tipos
Accept: application/json

### Obtener tipo por id
GET {{apiUrl}}/tipos/{{tipoId}}
Accept: application/json

### Crear tipo
POST {{apiUrl}}/tipos
Content-Type: application/json
Accept: application/json

{
	"nombre": "Pura Raza",
	"descripcion": "Caballo de pura raza, origen..."
}

### Actualizar tipo
PUT {{apiUrl}}/tipos/{{tipoId}}
Content-Type: application/json
Accept: application/json

{
	"id": {{tipoId}},
	"nombre": "Pura Raza Modificada",
	"descripcion": "Descripcion actualizada"
}

### Eliminar tipo
DELETE {{apiUrl}}/tipos/{{tipoId}}
Accept: application/json

### =========================
### CABALLOS
### =========================

### Listar caballos
GET {{apiUrl}}/caballos
Accept: application/json

### Obtener caballo por id
GET {{apiUrl}}/caballos/{{caballoId}}
Accept: application/json

### Crear caballo
POST {{apiUrl}}/caballos
Content-Type: application/json
Accept: application/json

{
	"nombre": "Tiro al Blanco",
	"edad": 15,
	"tipo": {
		"id": {{tipoId}}
	}
}

### Actualizar caballo
PUT {{apiUrl}}/caballos/{{caballoId}}
Content-Type: application/json
Accept: application/json

{
	"id": {{caballoId}},
	"nombre": "Tiro al Blanco Modificado",
	"edad": 16,
	"tipo": {
		"id": {{tipoId}}
	}
}

### Eliminar caballo
DELETE {{apiUrl}}/caballos/{{caballoId}}
Accept: application/json

